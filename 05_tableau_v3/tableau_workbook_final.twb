              <calculation class='tableau' formula='IIF(&#13;&#10;  INT([Parameters].[매개 변수 1]) + INT([Parameters].[매개 변수 2]) + INT([Parameters].[매개 변수 3]) = 0,&#13;&#10;  1.0,&#13;&#10;  (IIF([Parameters].[매개 변수 1], [demand_b2b], 0)&#13;&#10;  + IIF([Parameters].[매개 변수 2], [demand_b2c], 0)&#13;&#10;  + IIF([Parameters].[매개 변수 3], [demand_cv], 0))&#13;&#10;  / (INT([Parameters].[매개 변수 1]) + INT([Parameters].[매개 변수 2]) + INT([Parameters].[매개 변수 3]))&#13;&#10;)' />
            </column>
            <column caption='Constraint Score' datatype='real' name='[Calculation_1188023072526337]' role='measure' type='quantitative'>
