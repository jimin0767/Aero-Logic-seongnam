      <aliases enabled='yes' />
      <column caption='Adm Nm' datatype='string' name='[ADM_NM]' role='dimension' type='nominal' />
      <column caption='Demand Score' datatype='real' name='[Calculation_1188023072391168]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF(&#13;&#10;  INT([Parameters].[매개 변수 1]) + INT([Parameters].[매개 변수 2]) + INT([Parameters].[매개 변수 3]) = 0,&#13;&#10;  1.0,&#13;&#10;  (IIF([Parameters].[매개 변수 1], [demand_b2b], 0)&#13;&#10;  + IIF([Parameters].[매개 변수 2], [demand_b2c], 0)&#13;&#10;  + IIF([Parameters].[매개 변수 3], [demand_cv], 0))&#13;&#10;  / (INT([Parameters].[매개 변수 1]) + INT([Parameters].[매개 변수 2]) + INT([Parameters].[매개 변수 3]))&#13;&#10;)' />
      </column>
      <column caption='Constraint Score' datatype='real' name='[Calculation_1188023072526337]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(IIF([Parameters].[매개 변수 4], [score_airspace], 1.0)&#13;&#10;+ IIF([Parameters].[매개 변수 5], [score_obstacle], 1.0)&#13;&#10;+ IIF([Parameters].[매개 변수 6], [score_noise], 1.0)&#13;&#10;+ IIF([Parameters].[매개 변수 7], [score_robot], 1.0)&#13;&#10;+ IIF([Parameters].[매개 변수 8], [score_weather], 1.0)) / 5' />
      </column>
      <column caption='Is Strict Excluded' datatype='boolean' name='[Calculation_1188023072690178]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[hard_exclusion] AND [Parameters].[매개 변수 4] AND [Parameters].[매개 변수 9] = &quot;strict&quot;' />
      </column>
      <column caption='Final Score' datatype='real' name='[Calculation_1188023074463752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1188023072391168] * [Calculation_1188023072526337]' />
      </column>
      <column caption='Weather Percent' datatype='real' name='[Calculation_1188023086841866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([score_weather]) * 100' />
      </column>
      <column caption='Gu Nm' datatype='string' name='[GU_NM]' role='dimension' type='nominal' />
      <column caption='grid_master.csv' datatype='table' name='[__tableau_internal_object_id__].[grid_master.csv_5D0E0F7CF2624D31AB3DAF633F97DA68]' role='measure' type='quantitative' />
