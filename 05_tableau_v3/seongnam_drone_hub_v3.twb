    <worksheet name='H3 격자 지도'>
      <table>
        <view>
          <datasources>
            <datasource caption='Grid Master' name='textscan.95824d123b93bb16dca3' />
            <datasource caption='매개 변수' name='Parameters' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='공역' datatype='boolean' name='[p_con_airspace]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='소음' datatype='boolean' name='[p_con_noise]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='장애물' datatype='boolean' name='[p_con_obstacle]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='로봇접근' datatype='boolean' name='[p_con_robot]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='기상' datatype='boolean' name='[p_con_weather]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='B2B 기업수요' datatype='boolean' name='[p_demand_b2b]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='B2C 소비수요' datatype='boolean' name='[p_demand_b2c]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='상권활력지수' datatype='boolean' name='[p_demand_cv]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='textscan.95824d123b93bb16dca3'>
            <column caption='Constraint Score' datatype='real' name='[Constraint Score]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(IIF([Parameters].[p_con_airspace], [score_airspace], 1.0) + IIF([Parameters].[p_con_obstacle], [score_obstacle], 1.0) + IIF([Parameters].[p_con_noise],    [score_noise],    1.0) + IIF([Parameters].[p_con_robot],    [score_robot],    1.0) + IIF([Parameters].[p_con_weather],  [score_weather],  1.0)) / 5' />
            </column>
            <column caption='Demand Score' datatype='real' name='[Demand Score]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IIF(   INT([Parameters].[p_demand_b2b]) + INT([Parameters].[p_demand_b2c]) + INT([Parameters].[p_demand_cv]) = 0,   1.0,   (IIF([Parameters].[p_demand_b2b], [demand_b2b], 0)   + IIF([Parameters].[p_demand_b2c], [demand_b2c], 0)   + IIF([Parameters].[p_demand_cv], [demand_cv], 0))   / (INT([Parameters].[p_demand_b2b]) + INT([Parameters].[p_demand_b2c]) + INT([Parameters].[p_demand_cv])) )' />
            </column>
            <column caption='Final Score' datatype='real' name='[Final Score]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Demand Score] * [Constraint Score]' />
            </column>
            <column-instance column='[lat]' derivation='Avg' name='[avg:lat:qk]' pivot='key' type='quantitative' />
            <column-instance column='[lon]' derivation='Avg' name='[avg:lon:qk]' pivot='key' type='quantitative' />
            <column aggregation='Avg' datatype='real' name='[demand_b2b]' role='measure' type='quantitative' />
            <column aggregation='Avg' datatype='real' name='[demand_b2c]' role='measure' type='quantitative' />
            <column aggregation='Avg' datatype='real' name='[demand_cv]' role='measure' type='quantitative' />
            <column datatype='string' name='[h3_index]' role='dimension' type='nominal' />
            <column aggregation='Avg' datatype='real' name='[lat]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
            <column aggregation='Avg' datatype='real' name='[lon]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
            <column-instance column='[h3_index]' derivation='None' name='[none:h3_index:nk]' pivot='key' type='nominal' />
            <column aggregation='Avg' datatype='real' name='[score_airspace]' role='measure' type='quantitative' />
            <column aggregation='Avg' datatype='real' name='[score_noise]' role='measure' type='quantitative' />
            <column aggregation='Avg' datatype='real' name='[score_obstacle]' role='measure' type='quantitative' />
            <column aggregation='Avg' datatype='real' name='[score_robot]' role='measure' type='quantitative' />
            <column aggregation='Avg' datatype='real' name='[score_weather]' role='measure' type='quantitative' />
            <column-instance column='[Final Score]' derivation='Sum' name='[sum:Final Score:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
