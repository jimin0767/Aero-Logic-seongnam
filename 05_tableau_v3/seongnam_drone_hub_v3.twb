    <worksheet name='거점 목록'>
      <table>
        <view>
          <datasources>
            <datasource caption='Scenario Hubs' name='textscan.d6deb7c770ea147e53f7' />
            <datasource caption='매개 변수' name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='공역 모드' datatype='string' name='[p_airspace_mode]' param-domain-type='list' role='measure' type='nominal' value='&quot;approval&quot;'>
              <calculation class='tableau' formula='&quot;approval&quot;' />
            </column>
            <column caption='공역' datatype='boolean' name='[p_con_airspace]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='소음' datatype='boolean' name='[p_con_noise]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='장애물' datatype='boolean' name='[p_con_obstacle]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='로봇접근' datatype='boolean' name='[p_con_robot]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
            <column caption='기상' datatype='boolean' name='[p_con_weather]' param-domain-type='list' role='measure' type='nominal' value='true'>
              <calculation class='tableau' formula='true' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='textscan.d6deb7c770ea147e53f7'>
            <column caption='Current Scenario ID' datatype='string' name='[Current Scenario ID]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;S&quot; + RIGHT(&quot;000&quot; + STR(   (IIF(NOT [Parameters].[p_con_weather],  1, 0)   + IIF(NOT [Parameters].[p_con_robot],   2, 0)   + IIF(NOT [Parameters].[p_con_noise],   4, 0)   + IIF(NOT [Parameters].[p_con_obstacle],8, 0)   + IIF(NOT [Parameters].[p_con_airspace],16, 0))   * 2   + IIF([Parameters].[p_airspace_mode] = &quot;strict&quot;, 1, 0)   + 1 ), 3)' />
            </column>
            <column caption='Is Active Scenario' datatype='boolean' name='[Is Active Scenario]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[scenario_id] = [Current Scenario ID]' />
            </column>
            <column aggregation='Avg' datatype='real' name='[cover_ds]' role='measure' type='quantitative' />
            <column datatype='string' name='[delivery_zone]' role='dimension' type='nominal' />
            <column datatype='string' name='[lot_name]' role='dimension' type='nominal' />
            <column-instance column='[Is Active Scenario]' derivation='None' name='[none:Is Active Scenario:nk]' pivot='key' type='nominal' />
            <column-instance column='[delivery_zone]' derivation='None' name='[none:delivery_zone:nk]' pivot='key' type='nominal' />
            <column-instance column='[lot_name]' derivation='None' name='[none:lot_name:nk]' pivot='key' type='nominal' />
            <column datatype='integer' name='[rank]' role='measure' type='quantitative' />
            <column datatype='string' name='[scenario_id]' role='dimension' type='nominal' />
            <column-instance column='[cover_ds]' derivation='Sum' name='[sum:cover_ds:qk]' pivot='key' type='quantitative' />
            <column-instance column='[rank]' derivation='Sum' name='[sum:rank:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[textscan.d6deb7c770ea147e53f7].[none:Is Active Scenario:nk]'>
            <groupfilter function='member' level='[none:Is Active Scenario:nk]' member='true' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <computed-sort column='[textscan.d6deb7c770ea147e53f7].[none:lot_name:nk]' direction='ASC' using='[textscan.d6deb7c770ea147e53f7].[sum:rank:qk]' />
          <slices>
            <column>[textscan.d6deb7c770ea147e53f7].[none:Is Active Scenario:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <color column='[textscan.d6deb7c770ea147e53f7].[none:delivery_zone:nk]' />
              <tooltip column='[textscan.d6deb7c770ea147e53f7].[sum:rank:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[textscan.d6deb7c770ea147e53f7].[none:lot_name:nk]</rows>
